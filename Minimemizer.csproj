<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>assets\Minimemizer.ico</ApplicationIcon>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <AssemblyName>Minimemizer</AssemblyName>
    <RootNamespace>Minimemizer</RootNamespace>
    <Version>0.5.8</Version>
    <AssemblyVersion>0.5.8.0</AssemblyVersion>
    <FileVersion>0.5.8.0</FileVersion>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="assets\Minimemizer.ico" LogicalName="Minimemizer.AppIcon.ico" />
  </ItemGroup>
</Project>
